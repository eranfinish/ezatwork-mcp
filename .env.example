# === EZ@Work API ===
EZ_API_BASE=https://api.ezatwork.com
PORT=8080

# === OAuth mode (Claude Desktop / Claude.ai) ===
# Leave these empty for local dev with API tokens (Claude Code / Cursor / Inspector)
#
# GOOGLE_CLIENT_ID=<your-google-oauth-client-id>.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>
# MCP_BASE_URL=https://mcp.ezatwork.com
#
# EZ_MCP_MASTER_TOKEN=ezw_pat_<master-token-from-api-tokens-settings>

# === API token mode (Claude Code / Cursor / MCP Inspector) ===
# When OAuth vars above are NOT set, every MCP request must carry:
#   Authorization: Bearer ezw_pat_<your-personal-token>
# Create your token at https://app.ezatwork.com/settings/api-tokens
